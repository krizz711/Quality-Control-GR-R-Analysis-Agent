# =============================================================================
# Arad Quality Agent — environment template (repo ROOT only)
# =============================================================================
# Setup:
#   cp .env.example .env
#   # Edit secrets below, then:
#   docker compose up --build
#
# Do NOT create a second .env under arad-quality-agent/ — that folder is legacy.
# =============================================================================

# --- Runtime ---
ENVIRONMENT=development
LOG_LEVEL=INFO
API_AUTH_KEY=replace-with-a-strong-random-secret-min-32-chars
JWT_SECRET=replace-with-a-strong-jwt-secret-min-32-chars
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002
ALLOW_MOCK_DATA=false

# --- Database ---
# Docker Compose maps TimescaleDB to host port 5433 (avoids local Postgres on 5432).
POSTGRES_DB=arad_quality
POSTGRES_USER=arad
POSTGRES_PASSWORD=replace-with-a-strong-db-password
# For API running on the host (make run-api / pytest):
DATABASE_URL=postgresql+asyncpg://arad:replace-with-a-strong-db-password@localhost:5433/arad_quality

# --- Kafka / MLflow ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Canonical measurement topic (publishers, scripts, and the live consumer must agree).
MEASUREMENTS_TOPIC=quality.measurements
MEASUREMENTS_DLQ_TOPIC=quality.measurements.dlq
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Redis ---
# Leave unset for docker compose (default redis://redis:6379 inside the stack).
# Uncomment ONLY when running the API on the host (make run-api):
# REDIS_URL=redis://localhost:6379/0

# --- Dashboard ---
# Leave unset for docker compose (dashboard reaches API at http://api:8000).
# Set only when running dashboard with: cd dashboard && npm run dev
# API_URL=http://localhost:8000
NEXT_PUBLIC_ALLOW_MOCK_DATA=false
DASHBOARD_URL=http://localhost:3000

# --- Notifications (optional) ---
SLACK_WEBHOOK_URL=
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=QUAL

# --- Email SMTP (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
ALERT_EMAIL_RECIPIENTS=

# --- SMS (optional) ---
SMS_WEBHOOK_URL=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=
SMS_TO_NUMBERS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Integrations (optional) ---
QMS_API_URL=
ML_TOOL_NAME=mlflow

# --- AI (optional — core GR&R/SPC work without this; deterministic fallback if quota/key missing) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Admin UIs (docker compose) ---
PGADMIN_DEFAULT_EMAIL=admin@arad.com
PGADMIN_DEFAULT_PASSWORD=replace-with-a-strong-pgadmin-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-grafana-password
