# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO
API_AUTH_KEY=replace-with-a-strong-random-secret
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOW_MOCK_DATA=false

# Database
POSTGRES_DB=arad_quality
POSTGRES_USER=arad
POSTGRES_PASSWORD=replace-with-a-strong-db-password
DATABASE_URL=postgresql+asyncpg://arad:replace-with-a-strong-db-password@localhost:5432/arad_quality

# Kafka / MLflow
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MLFLOW_TRACKING_URI=http://localhost:5000

# Dashboard build
API_URL=http://localhost:8000
NEXT_PUBLIC_ALLOW_MOCK_DATA=false

# Notifications
SLACK_WEBHOOK_URL=
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=QUAL

# AI
GEMINI_API_KEY=

# Admin tools
PGADMIN_DEFAULT_EMAIL=admin@arad.com
PGADMIN_DEFAULT_PASSWORD=replace-with-a-strong-pgadmin-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-grafana-password
